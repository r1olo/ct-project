{
  "name": "compiler",
  "version": "1.0.0",
  "description": "Compiler for MiniImp and MiniFun languages",
  "license": "ISC",
  "author": "Andrea Riolo Vinciguerra",
  "type": "commonjs",
  "scripts": {
    "build:minifun": "tsc --noEmit && esbuild src/mainfun.ts --bundle --outfile=dist/main.js --platform=node",
    "build:miniimp": "tsc --noEmit && esbuild src/mainimp.ts --bundle --outfile=dist/main.js --platform=node"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3"
  }
}
